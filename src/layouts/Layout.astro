---
import Header from "../components/Header.astro";
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link
			href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
			rel="stylesheet"
		/>
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css"
		/>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"
		/>
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
	</head>
	<body>
		<Header>
			<h1 class="text-center" style="color: var(--primary-color);">
				Nicolas Coria
			</h1>
		</Header>
		<div class="content-wrapper">
			<slot />
		</div>

		<!-- Footer -->
		<footer class="bg-dark text-white py-4 mt-5">
			<div class="container">
				<div class="row">
					<div class="col-md-4 mb-4">
						<h5 class="fw-bold" data-translate="footer.name">
							Nicolas Antonio Coria
						</h5>
						<p class="mb-0" data-translate="footer.title">
							Licenciado en Automatización y Robótica
						</p>
					</div>
					<div class="row mt-3">
						<div class="col-12 text-center">
							<p class="mb-0" data-translate="footer.copyright">
								&copy; 2026 Nicolas Coria. Todos los derechos
								reservados.
							</p>
						</div>
					</div>
				</div>
			</div>
		</footer>

		<!-- Bootstrap JS -->
		<script
			src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
		></script>
		<script
			src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
		></script>
	</body>
</html>

<style is:global>
	:root {
		--primary-color: rgb(17, 60, 105);
		--secondary-color: rgb(62, 125, 218);
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family:
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			"Segoe UI",
			Roboto,
			Oxygen,
			Ubuntu,
			Cantarell,
			"Open Sans",
			"Helvetica Neue",
			sans-serif;
	}

	.content-wrapper {
		padding-top: 180px;
	}

	@media (max-width: 991px) {
		.content-wrapper {
			padding-top: 130px;
		}
	}

	.btn-primary {
		background-color: var(--primary-color);
		border-color: var(--primary-color);
	}

	.btn-primary:hover {
		background-color: var(--secondary-color);
		border-color: var(--secondary-color);
	}

	.text-primary {
		color: var(--primary-color) !important;
	}

	.bg-primary {
		background-color: var(--primary-color) !important;
	}
</style>

<script>
	// Importar traducciones
	import { translations, getTranslation } from "../utils/translations.js";

	// Estado del idioma
	let currentLanguage = localStorage.getItem("language") || "es";

	// Función para actualizar el idioma
	function updateLanguage(lang: string) {
		currentLanguage = lang;
		localStorage.setItem("language", lang);

		// Actualizar botones de idioma
		document.querySelectorAll(".language-btn").forEach((btn: Element) => {
			const button = btn as HTMLElement;
			button.classList.toggle("active", button.dataset.lang === lang);
		});

		// Actualizar atributo lang del HTML
		document.documentElement.lang = lang;

		// Actualizar todos los elementos con data-translate
		document
			.querySelectorAll("[data-translate]")
			.forEach((element: Element) => {
				const el = element as HTMLElement;
				const key = el.dataset.translate;
				if (key) {
					const translation = getTranslation(lang, key);
					if (translation && translation !== key) {
						el.textContent = translation;
					}
				}
			});

		// Actualizar elementos específicos sin data-translate
		updateSpecificElements(lang);
	}

	// Función para actualizar elementos específicos
	function updateSpecificElements(lang: string) {
		const t = translations[lang as keyof typeof translations];

		// Hero section
		const heroTitle = document.querySelector(".hero h1.display-4");
		if (heroTitle && t.hero) heroTitle.textContent = t.hero.title;

		const heroSubtitle = document.querySelector(".hero .lead");
		if (heroSubtitle && t.hero) heroSubtitle.textContent = t.hero.subtitle;

		const viewProjectsBtn = document.querySelector(".hero .btn-light");
		if (viewProjectsBtn && t.hero)
			viewProjectsBtn.textContent = t.hero.viewProjects;

		const contactBtn = document.querySelector(".hero .btn-outline-light");
		if (contactBtn && t.hero) contactBtn.textContent = t.hero.contact;

		// About section
		const aboutTitle = document.querySelector("#sobre-mi .display-5");
		if (aboutTitle && t.about) aboutTitle.textContent = t.about.title;

		const aboutSubtitle = document.querySelector(
			"#sobre-mi .lead.text-muted",
		);
		if (aboutSubtitle && t.about)
			aboutSubtitle.textContent = t.about.subtitle;

		const profileTitle = document.querySelector("#sobre-mi .card-title");
		if (profileTitle && t.about)
			profileTitle.textContent = t.about.profileTitle;

		// Experience section
		const expTitle = document.querySelector("#experiencia .display-5");
		if (expTitle && t.experience) expTitle.textContent = t.experience.title;

		const expSubtitle = document.querySelector(
			"#experiencia .lead.text-muted",
		);
		if (expSubtitle && t.experience)
			expSubtitle.textContent = t.experience.subtitle;

		// Skills section
		const skillsTitle = document.querySelector("#habilidades .display-5");
		if (skillsTitle && t.skills) skillsTitle.textContent = t.skills.title;

		const skillsSubtitle = document.querySelector(
			"#habilidades .lead.text-muted",
		);
		if (skillsSubtitle && t.skills)
			skillsSubtitle.textContent = t.skills.subtitle;

		// Footer
		const footerName = document.querySelector("footer h5");
		if (footerName && t.footer) footerName.textContent = t.footer.name;

		const footerTitle = document.querySelector("footer p.mb-0");
		if (footerTitle && t.footer) footerTitle.textContent = t.footer.title;

		const footerCopyright = document.querySelector("footer .text-center p");
		if (footerCopyright && t.footer)
			footerCopyright.textContent = t.footer.copyright;
	}

	// Inicialización cuando el DOM está listo
	document.addEventListener("DOMContentLoaded", () => {
		// Configurar event listeners para botones de idioma
		document.querySelectorAll(".language-btn").forEach((btn: Element) => {
			const button = btn as HTMLElement;
			button.addEventListener("click", () => {
				if (button.dataset.lang) {
					updateLanguage(button.dataset.lang);
				}
			});
		});

		// Cargar idioma guardado
		updateLanguage(currentLanguage);
	});

	// Script original del header
	const header = document.querySelector("header");
	let lastScroll = 0;

	window.addEventListener("scroll", () => {
		const currentScroll = window.pageYOffset;

		if (currentScroll <= 0) {
			header?.classList.remove("scroll-up");
			return;
		}

		if (
			currentScroll > lastScroll &&
			!header?.classList.contains("scroll-down")
		) {
			header?.classList.remove("scroll-up");
			header?.classList.add("scroll-down");
		} else if (
			currentScroll < lastScroll &&
			header?.classList.contains("scroll-down")
		) {
			header?.classList.remove("scroll-down");
			header?.classList.add("scroll-up");
		}
		lastScroll = currentScroll;
	});
</script>
