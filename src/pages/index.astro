                                            >Variadores y Drives</span
                                        >
                                        <span class="text-primary fw-bold"
                                            >90%</span
                                        >
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div
                                            class="progress-bar skill-bar"
                                            role="progressbar"
                                            data-skill="90"
                                        >
                                        </div>
                                    </div>
                                </div>

                                <div class="skill-item mb-3">
                                    <div
                                        class="d-flex justify-content-between align-items-center mb-2"
                                    >
                                        <span
                                            class="fw-medium"
                                            data-translate="skills.automationSkills.scada"
                                            >SCADA/HMI</span
                                        >
                                        <span class="text-primary fw-bold"
                                            >80%</span
                                        >
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div
                                            class="progress-bar skill-bar"
                                            role="progressbar"
                                            data-skill="80"
                                        >
                                        </div>
                                    </div>
                                </div>

                                <div class="skill-item mb-3">
                                    <div
                                        class="d-flex justify-content-between align-items-center mb-2"
                                    >
                                        <span
                                            class="fw-medium"
                                            data-translate="skills.automationSkills.electricalPlans"
                                            >Planos Eléctricos</span
                                        >
                                        <span class="text-primary fw-bold"
                                            >85%</span
                                        >
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div
                                            class="progress-bar skill-bar"
                                            role="progressbar"
                                            data-skill="85"
                                        >
                                        </div>
                                    </div>
                                </div>

                                <div class="skill-item mb-3">
                                    <div
                                        class="d-flex justify-content-between align-items-center mb-2"
                                    >
                                        <span
                                            class="fw-medium"
                                            data-translate="skills.automationSkills.processControl"
                                            >Control de Procesos</span
                                        >
                                        <span class="text-primary fw-bold"
                                            >90%</span
                                        >
                                    </div>
                                    <div class="progress" style="height: 8px;">
