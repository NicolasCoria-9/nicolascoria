---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Imagen from "../assets/Doc.jpeg";
---

<Layout
    title="Nicolas Coria - Especialista en Automatización y Robótica"
    url="https://nicolascoria-9.github.io/nicolascoria/"
>
    <main>
        <!-- Hero Section -->
        <section class="hero position-relative">
            <div class="hero-overlay"></div>
            <div class="hero-bg"></div>

            <!-- Sincronismo Tecnológico -->
            <div class="tech-sync-overlay">
                <div class="sync-lines">
                    <div class="sync-line line-1"></div>
                    <div class="sync-line line-2"></div>
                    <div class="sync-line line-3"></div>
                    <div class="sync-line line-4"></div>
                    <div class="sync-line line-5"></div>
                </div>
                <div class="sync-nodes">
                    <div class="sync-node node-1"></div>
                    <div class="sync-node node-2"></div>
                    <div class="sync-node node-3"></div>
                    <div class="sync-node node-4"></div>
                    <div class="sync-node node-5"></div>
                    <div class="sync-node node-6"></div>
                </div>
                <div class="sync-pulses">
                    <div class="pulse pulse-1"></div>
                    <div class="pulse pulse-2"></div>
                    <div class="pulse pulse-3"></div>
                </div>
            </div>

            <div class="hero-content">
                <div class="container">
                    <div
                        class="row justify-content-center min-vh-100 align-items-center"
                    >
                        <div class="col-lg-8 text-center">
                            <!-- Imagen Personal -->
                            <div class="profile-image-container mb-4">
                                <Image
                                    src={Imagen}
                                    alt="Nicolas Coria"
                                    class="profile-image rounded-circle"
                                    width={200}
                                    height={200}
                                />
                            </div>

                            <h1 class="display-4 fw-bold mb-4 text-white">
                                Lic. Nicolas Antonio Coria
                            </h1>
                            <p class="lead mb-4 text-white lead">
                                Especialista en Automatización y Robótica |
                                Licenciado en automatizacion y robotica con
                                experiencia en PLC, HMI, SCADA y sistemas
                                industriales varios.
                            </p>
                            <div
                                class="d-flex justify-content-center gap-3 flex-wrap mt-3"
                            >
                                <a
                                    href="/nicolascoria/Curriculum_NicolasCoria.pdf"
                                    download="Curriculum_NicolasCoria.pdf"
                                    class="btn btn-primary btn-lg download-btn"
                                    data-translate="hero.downloadCV"
                                >
                                    <i class="bi bi-download me-2"></i>
                                    <span>Descargar CV</span>
                                </a>
                                <a
                                    href="/nicolascoria/Carta_presentacion.pdf"
                                    download="Carta_presentacion.pdf"
                                    class="btn btn-secondary btn-lg download-btn"
                                    data-translate="hero.downloadLetter"
                                >
                                    <i class="bi bi-file-text me-2"></i>
                                    <span>Descargar Carta de Presentación</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- About Me Section -->
        <section id="sobre-mi" class="py-5">
            <div class="container">
                <div class="row">
                    <div class="col-12 text-center mb-5">
                        <h2
                            class="display-5 fw-bold"
                            style="color: rgb(17, 60, 105);"
                            data-translate="about.title"
                        >
                            Sobre Mí
                        </h2>
                        <p
                            class="lead text-muted"
                            data-translate="about.subtitle"
                        >
                            Mi perfil profesional y trayectoria en
                            automatización industrial
                        </p>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-4">
                                <h4
                                    class="card-title fw-bold mb-3"
                                    style="color: rgb(17, 60, 105);"
                                    data-translate="about.profileTitle"
                                >
                                    Perfil Profesional
                                </h4>
                                <p
                                    class="mb-3"
                                    data-translate="about.profileText1"
                                >
                                    Especialista en Automatización y Robótica
                                    con más de 4 años de experiencia en el
                                    sector industrial. Apasionado por la
                                    implementación de soluciones tecnológicas
                                    que optimizan procesos y mejoran la
                                    eficiencia operativa.
                                </p>
                                <p
                                    class="mb-4"
                                    data-translate="about.profileText2"
                                >
                                    Mi enfoque se centra en el desarrollo de
                                    sistemas de control integrales, desde la
                                    programación de PLCs hasta la implementación
                                    de sistemas SCADA/HMI, siempre buscando la
                                    excelencia técnica y la innovación continua.
                                </p>

                                <h5
                                    class="fw-bold mb-3"
                                    data-translate="about.education"
                                >
                                    Formación Académica
                                </h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="d-flex align-items-start">
                                            <i
                                                class="bi bi-mortarboard-fill me-2"
                                                style="color: rgb(62, 125, 218);"
                                            ></i>
                                            <div>
                                                <h6
                                                    class="mb-1"
                                                    data-translate="about.degree1"
                                                >
                                                    Licenciatura en
                                                    Automatización y Robótica
                                                </h6>
                                                <p
                                                    class="text-muted small mb-0"
                                                >
                                                    UNRaf · 2024-2025
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="d-flex align-items-start">
                                            <i
                                                class="bi bi-mortarboard-fill me-2"
                                                style="color: rgb(62, 125, 218);"
                                            ></i>
                                            <div>
                                                <h6
                                                    class="mb-1"
                                                    data-translate="about.degree2"
                                                >
                                                    Técnico Universitario en
                                                    Mecatrónica
                                                </h6>
                                                <p
                                                    class="text-muted small mb-0"
                                                >
                                                    UNRaf · 2020-2024
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="d-flex align-items-start">
                                            <i
                                                class="bi bi-mortarboard-fill me-2"
                                                style="color: rgb(62, 125, 218);"
                                            ></i>
                                            <div>
                                                <h6
                                                    class="mb-1"
                                                    data-translate="about.degree3"
                                                >
                                                    Técnico en Electrónica
                                                </h6>
                                                <p
                                                    class="text-muted small mb-0"
                                                >
                                                    EETP Nº 460 · 2013-2018
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="d-flex align-items-start">
                                            <i
                                                class="bi bi-award-fill me-2"
                                                style="color: rgb(62, 125, 218);"
                                            ></i>
                                            <div>
                                                <h6
                                                    class="mb-1"
                                                    data-translate="about.certifications"
                                                >
                                                    Certificaciones Múltiples
                                                </h6>
                                                <p
                                                    class="text-muted small mb-0"
                                                    data-translate="about.certificationsText"
                                                >
                                                    PLC, SCADA, Redes
                                                    Industriales
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-4">
                                <h4
                                    class="card-title fw-bold mb-4"
                                    style="color: rgb(17, 60, 105);"
                                    data-translate="about.statistics"
                                >
                                    Estadísticas
                                </h4>

                                <div class="stat-item mb-4">
                                    <div
                                        class="d-flex align-items-center justify-content-between"
                                    >
                                        <div>
                                            <i
                                                class="bi bi-briefcase-fill me-2"
                                                style="color: rgb(62, 125, 218); font-size: 1.5rem;"
                                            ></i>
                                            <span
                                                class="fw-medium"
                                                data-translate="about.experience"
                                                >Años de Experiencia</span
                                            >
                                        </div>
                                        <span
                                            class="display-6 fw-bold text-primary"
                                            >4+</span
                                        >
                                    </div>
                                </div>

                                <div class="stat-item mb-4">
                                    <div
                                        class="d-flex align-items-center justify-content-between"
                                    >
                                        <div>
                                            <i
                                                class="bi bi-diagram-3-fill me-2"
                                                style="color: rgb(62, 125, 218); font-size: 1.5rem;"
                                            ></i>
                                            <span
                                                class="fw-medium"
                                                data-translate="about.projects"
                                                >Proyectos Completados</span
                                            >
                                        </div>
                                        <span
                                            class="display-6 fw-bold text-primary"
                                            >15+</span
                                        >
                                    </div>
                                </div>

                                <div class="mt-4 pt-3 border-top">
                                    <h6
                                        class="fw-bold mb-3"
                                        data-translate="about.specializations"
                                    >
                                        Áreas de Especialización
                                    </h6>
                                    <div class="tech-stack">
                                        <span
                                            class="badge tech-badge"
                                            data-translate="about.specializationsList.automation"
                                            >Automatización</span
                                        >
                                        <span
                                            class="badge tech-badge"
                                            data-translate="about.specializationsList.scada"
                                            >SCADA/HMI</span
                                        >
                                        <span
                                            class="badge tech-badge"
                                            data-translate="about.specializationsList.plc"
                                            >PLC</span
                                        >
                                        <span
                                            class="badge tech-badge"
                                            data-translate="about.specializationsList.processControl"
                                            >Control de Procesos</span
                                        >
                                        <span
                                            class="badge tech-badge"
                                            data-translate="about.specializationsList.maintenance"
                                            >Mantenimiento</span
                                        >
                                        <span
                                            class="badge tech-badge"
                                            data-translate="about.specializationsList.electricalDesign"
                                            >Diseño Eléctrico</span
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Experience Section -->
        <section id="experiencia" class="py-5 bg-light">
            <div class="container">
                <div class="row">
                    <div class="col-12 text-center mb-5">
                        <h2
                            class="display-5 fw-bold"
                            style="color: rgb(17, 60, 105);"
                            data-translate="experience.title"
                        >
                            Experiencia Laboral
                        </h2>
                        <p
                            class="lead text-muted"
                            data-translate="experience.subtitle"
                        >
                            Mi trayectoria profesional en el sector industrial
                        </p>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-start">
                                    <div class="icon-wrapper me-3">
                                        <i class="bi bi-building"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h4
                                            class="card-title fw-bold mb-2"
                                            data-translate="experience.jobs.unraf.title"
                                        >
                                            Universidad Nacional de Rafaela
                                        </h4>
                                        <p
                                            class="text-muted mb-2"
                                            data-translate="experience.jobs.unraf.position"
                                        >
                                            Docente de catedra y Adscripto
                                        </p>
                                        <div class="tech-stack mb-2">
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.unraf.skills.plcProgramming"
                                            >
                                                Programación PLC
                                            </span>
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.unraf.skills.ladder"
                                            >
                                                Ladder
                                            </span>
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.unraf.skills.pneumatics"
                                            >
                                                Neumática
                                            </span>
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.unraf.skills.logicControl"
                                            >
                                                Control Lógico
                                            </span>
                                        </div>
                                        <small
                                            class="text-primary fw-bold"
                                            data-translate="experience.jobs.unraf.period"
                                        >
                                            2025 - Actualidad
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-start">
                                    <div class="icon-wrapper me-3">
                                        <i class="bi bi-gear"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h4
                                            class="card-title fw-bold mb-2"
                                            data-translate="experience.jobs.sodecar.title"
                                        >
                                            Sodecar S.A.
                                        </h4>
                                        <p
                                            class="text-muted mb-2"
                                            data-translate="experience.jobs.sodecar.position"
                                        >
                                            Oficina técnica
                                        </p>
                                        <div class="tech-stack mb-2">
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.sodecar.skills.siemensPlc"
                                            >
                                                PLC Siemens
                                            </span>
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.sodecar.skills.fatekPlc"
                                            >
                                                PLC Fatek
                                            </span>
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.sodecar.skills.scada"
                                            >
                                                SCADA/HMI
                                            </span>
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.sodecar.skills.autocad"
                                            >
                                                AutoCAD
                                            </span>
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.sodecar.skills.refrigeration"
                                            >
                                                Procesos Frigoríficos
                                            </span>
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.sodecar.skills.dryers"
                                            >
                                                Secaderos
                                            </span>
                                        </div>
                                        <small
                                            class="text-primary fw-bold"
                                            data-translate="experience.jobs.sodecar.period"
                                        >
                                            2023 - Actualidad</small
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="card shadow-sm border-0">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-start">
                                    <div class="icon-wrapper me-3">
                                        <i class="bi bi-tools"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h4
                                            class="card-title fw-bold mb-2"
                                            data-translate="experience.jobs.mahle.title"
                                        >
                                            Mahle Group
                                        </h4>
                                        <p
                                            class="text-muted mb-2"
                                            data-translate="experience.jobs.mahle.position"
                                        >
                                            Mantenimiento Eléctrico
                                        </p>
                                        <div class="tech-stack mb-2">
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.mahle.skills.preventiveMaintenance"
                                                >Mantenimiento Preventivo</span
                                            >
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.mahle.skills.electricalDiagnosis"
                                                >Diagnóstico Eléctrico</span
                                            >
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.mahle.skills.electricalPlans"
                                                >Planos Eléctricos</span
                                            >
                                            <span
                                                class="badge tech-badge"
                                                data-translate="experience.jobs.mahle.skills.instrumentation"
                                                >Instrumental</span
                                            >
                                        </div>
                                        <small
                                            class="text-primary fw-bold"
                                            data-translate="experience.jobs.mahle.period"
                                            >2021 - 2023</small
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Skills Section -->
        <section id="habilidades" class="py-5">
            <div class="container">
                <div class="row">
                    <div class="col-12 text-center mb-5">
                        <h2
                            class="display-5 fw-bold"
                            style="color: rgb(17, 60, 105);"
                            data-translate="skills.title"
                        >
                            Habilidades Técnicas
                        </h2>
                        <p
                            class="lead text-muted"
                            data-translate="skills.subtitle"
                        >
                            Nivel de dominio en automatización y software
                        </p>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-lg-6">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-body p-4">
                                <h4
                                    class="card-title fw-bold mb-4"
