---
import Layout from "../layouts/Layout.astro";
import profileImage from "/nicolascoria/assets/Doc.jpeg";
import background from "/nicolascoria/assets/background.svg";
---

<Layout>
	<!-- Navigation -->
	<nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
		<div class="container">
			<a class="navbar-brand" href="#hero">Lic. Nicolás Coria</a>
			<button
				class="navbar-toggler"
				type="button"
				data-bs-toggle="collapse"
				data-bs-target="#navbarNav"
			>
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav ms-auto">
					<li class="nav-item">
						<a class="nav-link" href="#about">Sobre mí</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="#projects">Proyectos</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="#skills">Habilidades</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="#contact">Contact</a>
					</li>
				</ul>
			</div>
		</div>
	</nav>

	<!-- Hero Section -->
	<section id="hero" class="hero-section">
		<div class="hero-content">
			<div class="container">
				<div class="row align-items-center gx-5">
					<div class="col-lg-7">
						<h1 class="hero-title">Nicolás Antonio Coria</h1>
						<p class="hero-subtitle">
							Especialista en Automatización y Robótica
						</p>
						<div class="hero-buttons">
							<a
								href="#projects"
								class="btn btn-primary btn-lg me-3"
								>Ver Proyectos</a
							>
							<a
								href="#contact"
								class="btn btn-outline-light btn-lg"
								>Contactar</a
							>
						</div>
						<div class="hero-social">
							<a
								href="https://github.com/NicolasCoria-9"
								class="social-link"
								target="_blank"
							>
								<i class="fab fa-github"></i>
								<span>GitHub</span>
							</a>
							<a
								href="https://www.linkedin.com/in/nicolas-coria-400340193/"
								class="social-link"
								target="_blank"
							>
								<i class="fab fa-linkedin"></i>
								<span>LinkedIn</span>
							</a>
						</div>
					</div>
					<div class="col-lg-5">
						<div class="hero-image-container">
							<div class="hero-image-placeholder">
								<img
									src={profileImage.src}
									alt="Nicolás Antonio Coria"
									loading="lazy"
									decoding="async"
								/>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="hero-particles">
			<div class="particle"></div>
			<div class="particle"></div>
			<div class="particle"></div>
			<div class="particle"></div>
			<div class="particle"></div>
		</div>
		<div class="rain-container">
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
			<div class="rain-drop"></div>
		</div>
	</section>

	<!-- About Section -->
	<section id="about" class="py-5">
		<div class="container">
			<div class="row align-items-center">
				<div class="col-lg-6">
					<h2 class="section-title">Sobre mí</h2>
					<p class="lead">
						Licenciado especializado en automatización industrial y
						control de procesos con sólida experiencia en sistemas
						SCADA/HMI.
					</p>
					<p>
						Licenciado en Automatización y Robótica con formación en
						Mecatrónica y Electrónica. Me especializo en
						programación de PLC (Siemens, Fatek, Schneider),
						desarrollo de sistemas SCADA/HMI, y diseño de soluciones
						de automatización para la industria. Actualmente trabajo
						en Sodecar S.A. donde lidero proyectos de automatización
						para procesos frigoríficos e industriales.
					</p>
					<div class="row mt-4">
						<div class="col-6">
							<div class="stat-item">
								<h3>5+</h3>
								<p>Años de experiencia</p>
							</div>
						</div>
						<div class="col-6">
							<div class="stat-item">
								<h3>20+</h3>
								<p>Proyectos industriales</p>
							</div>
						</div>
					</div>
				</div>
				<div class="col-lg-6">
					<div class="about-image">
						<div class="image-placeholder">
							<i class="fas fa-network-wired"></i>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Projects Section -->
	<section id="projects" class="py-5 bg-light">
		<div class="container">
			<h2 class="section-title text-center">Proyectos Destacados</h2>
			<div class="row">
				<div class="col-lg-4 col-md-6 mb-4">
					<div class="project-card">
						<div class="project-image">
							<div class="image-placeholder">
								<i class="fas fa-industry"></i>
							</div>
						</div>
						<div class="project-content">
							<h4>Automatización Condensadores de Amoníaco</h4>
							<p>
								Arquitectura distribuida en Siemens + SCADA
								Weintek para control de condensadores
								industriales.
							</p>
							<div class="project-tech">
								<span class="badge bg-primary">Siemens PLC</span
								>
								<span class="badge bg-primary"
									>Weintek SCADA</span
								>
								<span class="badge bg-primary">Ethernet IP</span
								>
							</div>
						</div>
					</div>
				</div>
				<div class="col-lg-4 col-md-6 mb-4">
					<div class="project-card">
						<div class="project-image">
							<div class="image-placeholder">
								<i class="fas fa-temperature-low"></i>
							</div>
						</div>
						<div class="project-content">
							<h4>Automatización Secaderos Industriales</h4>
							<p>
								Programación en PLC Fatek + HMI Weintek para
								control de secaderos industriales.
							</p>
							<div class="project-tech">
								<span class="badge bg-primary">Fatek PLC</span>
								<span class="badge bg-primary">Weintek HMI</span
								>
								<span class="badge bg-primary"
									>Control de Procesos</span
								>
							</div>
						</div>
					</div>
				</div>
				<div class="col-lg-4 col-md-6 mb-4">
					<div class="project-card">
						<div class="project-image">
							<div class="image-placeholder">
								<i class="fas fa-snowflake"></i>
							</div>
						</div>
						<div class="project-content">
							<h4>Automatización Cámaras Frigoríficas</h4>
							<p>
								Programación Schneider + visualización por
								controladores industriales (CCG o IEA).
							</p>
							<div class="project-tech">
								<span class="badge bg-primary"
									>Schneider PLC</span
								>
								<span class="badge bg-primary">CCG/IEA</span>
								<span class="badge bg-primary"
									>Control Frigorífico</span
								>
							</div>
						</div>
					</div>
				</div>
				<div class="col-lg-4 col-md-6 mb-4">
					<div class="project-card">
						<div class="project-image">
							<div class="image-placeholder">
								<i class="fas fa-chart-line"></i>
							</div>
						</div>
						<div class="project-content">
							<h4>SCADA's Implementados</h4>
							<p>
								Programación en EasyBuilder Pro con diferentes
								protocolos de comunicación industriales
							</p>
							<div class="project-tech">
								<span class="badge bg-primary"
									>EasyBuilder Pro</span
								>
								<span class="badge bg-primary"
									>RTU - TCP/IP</span
								>
								<span class="badge bg-primary"
									>Control Industrial</span
								>
							</div>
						</div>
					</div>
				</div>
				<div class="col-lg-4 col-md-6 mb-4">
					<div class="project-card">
						<div class="project-image">
							<div class="image-placeholder">
								<i class="fas fa-cogs"></i>
							</div>
						</div>
						<div class="project-content">
							<h4>Manufacturing Execution System (MES)</h4>
							<p>
								Implementación de sistema de gestión de
								producción para optimizar procesos industriales.
							</p>
							<div class="project-tech">
								<span class="badge bg-primary"
									>Sistema de Gestión</span
								>
								<span class="badge bg-primary"
									>Optimización de Procesos</span
								>
								<span class="badge bg-primary"
									>Gestión de Producción</span
								>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Skills Section -->
	<section id="skills" class="py-5">
		<div class="container">
			<h2 class="section-title text-center">Habilidades</h2>
			<div class="row">
				<div class="col-lg-6">
					<h4 class="mb-4">Automatización Industrial</h4>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>Winprollader / Upperlogic</span>
							<span>95%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 95%"></div>
						</div>
					</div>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>EasyBuilder Pro</span>
							<span>92%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 92%"></div>
						</div>
					</div>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>Tia Portal</span>
							<span>90%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 90%"></div>
						</div>
					</div>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>EcoStruxure Machine</span>
							<span>85%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 85%"></div>
						</div>
					</div>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>Studio 5000 / RSLogix</span>
							<span>80%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 80%"></div>
						</div>
					</div>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>Controladores Industriales</span>
							<span>90%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 90%"></div>
						</div>
					</div>
				</div>
				<div class="col-lg-6">
					<h4 class="mb-4">Software y Diseño</h4>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>AutoCAD</span>
							<span>80%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 80%"></div>
						</div>
					</div>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>HTML/CSS/JavaScript</span>
							<span>70%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 70%"></div>
						</div>
					</div>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>Python</span>
							<span>65%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 60%"></div>
						</div>
					</div>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>Office Avanzado</span>
							<span>80%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 80%"></div>
						</div>
					</div>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>SQL / Bases de Datos</span>
							<span>50%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 50%"></div>
						</div>
					</div>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>Gestión de Proyectos</span>
							<span>90%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 90%"></div>
						</div>
					</div>
					<div class="skill-item">
						<div class="d-flex justify-content-between mb-1">
							<span>IOT Industrial</span>
							<span>60%</span>
						</div>
						<div class="progress mb-3">
							<div class="progress-bar" style="width: 60%"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section
		id="contact"
		class="py-5 text-white"
		style="background-color: #212529;"
	>
		<div class="container">
			<div class="row justify-content-center">
				<div class="col-md-8">
					<div
						class="card shadow"
						style="border: none; border-radius: 15px; background-color: #212529; background: linear-gradient(135deg, rgba(17, 60, 105, 0.95), rgba(62, 125, 218, 0.9);"
					>
						<div class="card-body p-4">
							<h2
								class="text-white mb-4"
								style="font-weight: 600;"
							>
								Contacto
							</h2>
							<form
								action="https://api.web3forms.com/submit"
								method="POST"
								class="needs-validation"
								novalidate
							>
								<input
									type="hidden"
									name="access_key"
									value="04eda78e-e58a-4822-ac83-d748466a31f2"
								/>
								<input
									type="hidden"
									name="subject"
									value="Nuevo envío de formulario de contacto"
								/>
								<input
									type="hidden"
									name="reply_to"
									value="nicolasacoria@gmail.com"
								/>
								<div class="mb-3">
									<label
										for="nombre"
										class="form-label text-white"
										style="font-weight: 500;">Nombre</label
									>
									<input
										type="text"
										class="form-control"
										id="nombre"
										name="nombre"
										style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.3); color: white; border-radius: 8px;"
										required
									/>
								</div>
								<div class="mb-3">
									<label
										for="email"
										class="form-label text-white"
										style="font-weight: 500;"
										>Correo Electrónico</label
									>
									<input
										type="email"
										class="form-control"
										id="email"
										name="email"
										style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.3); color: white; border-radius: 8px;"
										required
									/>
								</div>
								<div class="mb-3">
									<label
										for="mensaje"
										class="form-label text-white"
										style="font-weight: 500;">Mensaje</label
									>
									<textarea
										class="form-control"
										id="mensaje"
										name="mensaje"
										rows="4"
										style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.3); color: white; border-radius: 8px; resize: vertical;"
										required></textarea>
								</div>
								<div class="text-center mt-4">
									<button
										type="submit"
										class="btn btn-lg px-5"
										style="background: linear-gradient(45deg, rgb(62, 125, 218), rgb(17, 60, 105)); border: none; border-radius: 25px; color: white; font-weight: 600; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(62, 125, 218, 0.3);"
										onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(62, 125, 218, 0.4)';"
										onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(62, 125, 218, 0.3)';"
										>Enviar Mensaje</button
									>
								</div>
								<div id="result" class="mt-3 text-center"></div>
							</form>
						</div>
					</div>
				</div>
				<div class="contact-info text-center mt-4">
					<p>
						<i class="fas fa-envelope"></i> nicolasacoria@gmail.com
					</p>
					<p><i class="fas fa-phone"></i> +54 3492 328782</p>
					<p>
						<i class="fas fa-map-marker-alt"></i>Rafaela, Santa Fe,
						Argentina
					</p>
				</div>
			</div>
		</div>
	</section>
</Layout>

<!-- Footer -->
<footer class="bg-dark text-white py-3">
	<div class="container text-center">
		<p>&copy; 2026 Lic. Nicolás Coria. Todos los derechos reservados.</p>
	</div>
</footer>

<style>
	/* Variables */
	:root {
		--primary-color: #113c69;
		--secondary-color: #3e7dda;
		--accent-color: #ff6b6b;
		--text-light: #f8f9fa;
		--text-dark: #212529;
	}

	/* Global Styles */
	* {
		scroll-behavior: smooth;
	}

	body {
		font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
		color: var(--text-dark);
	}

	/* Navigation */
	.navbar {
		background: rgba(17, 60, 105, 0.95) !important;
		backdrop-filter: blur(10px);
		transition: all 0.3s ease;
	}

	.navbar-brand {
		font-weight: bold;
		font-size: 1.5rem;
		color: var(--text-light) !important;
	}

	.nav-link {
		color: var(--text-light) !important;
		margin: 0 10px;
		transition: color 0.3s ease;
	}

	.nav-link:hover {
		color: var(--secondary-color) !important;
	}

	/* Hero Section */
	.hero-section {
		min-height: 100vh;
		background: linear-gradient(
			135deg,
			var(--primary-color) 0%,
			var(--secondary-color) 100%
		);
		background-size: 400% 400%;
		animation: gradientShift 15s ease infinite;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow: hidden;
	}

	.hero-content {
		position: relative;
		z-index: 2;
	}

	.hero-title {
		font-size: 4rem;
		font-weight: bold;
		color: var(--text-light);
		margin-bottom: 1rem;
		animation: fadeInUp 1s ease;
	}

	.hero-image-container {
		text-align: center;
		animation: fadeInUp 1s ease 0.8s;
		animation-fill-mode: both;
	}

	.hero-image-placeholder {
		width: 350px;
		height: 350px;
		border-radius: 50%;
		background: linear-gradient(
			135deg,
			rgba(255, 255, 255, 0.1),
			rgba(255, 255, 255, 0.2)
		);
		border: 4px solid rgba(255, 255, 255, 0.3);
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto;
		color: var(--text-light);
		font-size: 5rem;
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease;
		overflow: hidden;
	}

	.hero-image-placeholder:hover {
		transform: scale(1.05);
		box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
	}

	.hero-image-placeholder img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 50%;
	}

	.hero-subtitle {
		font-size: 1.5rem;
		color: var(--text-light);
		margin-bottom: 2rem;
