                                    >
                                        <span
                                            class="fw-medium"
                                            data-translate="skills.automationSkills.plcProgramming"
                                            >Programación PLC</span
                                        >
                                        <span class="text-primary fw-bold"
                                            >95%</span
                                        >
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div
                                            class="progress-bar skill-bar"
                                            role="progressbar"
                                            data-skill="95"
                                        >
                                        </div>
                                    </div>
                                </div>

                                <div class="skill-item mb-3">
                                    <div
